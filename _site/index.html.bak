<!-- Page Content -->
<section id="home" class="page-section">
	<div class="banner-container">
  <div class="container banner-content">

    <div id="da-slider" class="da-slider">

    <!-- Slide 1 -->
    <div class="da-slide">
      <h2>Formal Methods</h2>
      <p>We develop mathematically grounded verification and runtime assurance methods to guarantee the safety and correctness of AI-driven systems.</p>
      <a href="/research/formal-methods" class="da-link button-outline">Learn More</a>
      <div class="da-img"></div>
    </div>

    <!-- Slide 2 -->
    <div class="da-slide">
      <h2>Safe LLM</h2>
      <p>We build compact and trustworthy domain-specific language models with improved interpretability, alignment, and robust decision-making.</p>
      <a href="/research/medical-ai" class="da-link button-outline">LLM Portfolio</a>
      <div class="da-img"></div>
    </div>

    <!-- Slide 3 -->
    <div class="da-slide">
      <h2>Medical AI</h2>
      <p>
        Our research spans ophthalmology, clinical decision support, and noise-robust diagnostic modeling, 
        powered by domain-specialized LLMs for safer and more interpretable medical reasoning.
      </p>
      <a href="/research/medical-ai" class="da-link button-outline">See Projects</a>
      <div class="da-img"></div>
    </div>


    <!-- Slide 4 -->
    <div class="da-slide">
      <h2>Robot Racing</h2>
      <p>We explore autonomous racing, RoboRacer(F1TENTH) robotics, and safe high-speed navigation under real-world uncertainty.</p>
      <a href="/team.html" class="da-link button-outline">Racing Lab</a>
      <div class="da-img"></div>
    </div>


      <nav class="da-arrows">
        <span class="da-arrows-prev"></span>
        <span class="da-arrows-next"></span>
      </nav>

    </div>

  </div>
</div>



</section>

<section id="aboutUs" class="page-section pDark pdingBtm30">
  <div class="container">
    <div class="heading text-center">
      <h2>About Us</h2>
      <p>
      AiX Lab at Gyeongsang National University advances 
        <strong>trustworthy AI</strong> through mathematically grounded verification,
        safe domain-specialized LLMs, clinically meaningful medical intelligence,
        and real-world autonomous racing platforms.
      </p>
    </div>

    <div class="row">
      <div class="col-md-3 col-sm-6">
        <div class="tray text-center">
          <h3><i class="fa fa-desktop color"></i> &nbsp;Research</h3>
          <p>We conduct research on the safety of software systems.</p>
        </div>
      </div>

      <div class="col-md-3 col-sm-6">
        <div class="tray text-center">
          <h3><i class="fa fa-cloud color"></i> &nbsp;Education</h3>
          <p>We provide education in AI, formal methods, and software engineering.</p>
        </div>
      </div>

      <div class="col-md-3 col-sm-6">
        <div class="tray text-center">
          <h3><i class="fa fa-gear color"></i> &nbsp;Development</h3>
          <p>We develop medical AI and autonomous driving software for racing.</p>
        </div>
      </div>

      <div class="col-md-3 col-sm-6">
        <div class="tray text-center">
          <h3><i class="fa fa-plane color"></i> &nbsp;Competition</h3>
          <p>We compete with other teams to build safer and more reliable software.</p>
        </div>
      </div>
    </div>
  </div>
</section>

---
layout: default
title: "News"
nav: news
